# Copy this file to .env.local and fill in your values

# Admin password — change this before going live
ADMIN_PASSWORD=your-secure-password-here

# Upstash Redis — get these from console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Cloudinary — server-side (used by /api/upload PDF route)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Cloudinary — public (used for direct browser-to-Cloudinary image uploads, bypassing Next.js body limit)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
